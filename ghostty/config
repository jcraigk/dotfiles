# Font
font-family = JetBrainsMono Nerd Font
font-size = 16
adjust-cell-height = 5%

# Window
window-height = 9999
window-width = 9999
window-padding-x = 8
window-padding-y = 8
split-divider-color = #303030

# Icon
macos-icon = chalkboard

# Cursor
cursor-style = bar
cursor-style-blink = true
adjust-cursor-thickness = 4
cursor-color = #c0c0c0
cursor-opacity = 1

# Jump between prompts (like Warp's command navigation)
keybind = cmd+shift+up=jump_to_prompt:-1
keybind = cmd+shift+down=jump_to_prompt:1

# Selection
selection-background = #303050
selection-foreground = cell-foreground

# Colors (matching Warp default dark theme)
background = #000000
foreground = #e4e4e4

# Normal colors
palette = 0=#000000
palette = 1=#ff5f5f
palette = 2=#5faf5f
palette = 3=#d7af5f
palette = 4=#5f87d7
palette = 5=#af5faf
palette = 6=#5fafaf
palette = 7=#c6c6c6

# Bright colors
palette = 8=#585858
palette = 9=#ff8787
palette = 10=#87d787
palette = 11=#ffd787
palette = 12=#87afd7
palette = 13=#d787d7
palette = 14=#87d7d7
palette = 15=#e4e4e4

# Keybindings
keybind = shift+enter=text:\n

# Dev: command blocks
command-blocks = true
command-blocks-padding-footer = 25
command-blocks-padding-header = 25
command-blocks-padding-left = 12
command-blocks-padding-right = 8
command-blocks-stripe-width = 4
command-blocks-separator-color = #303030
command-blocks-stripe-success = #5faf5f
command-blocks-stripe-error = #ff5f5f
command-blocks-stripe-signal = #d7af5f
command-blocks-tint-error = #2d0606
command-blocks-tint-success = #061906
command-blocks-tint-signal = #2d1f06
command-blocks-collapse-preview-lines = 0
# command-blocks-auto-collapse-threshold = 1
env = GHOSTTY_DEV=1
